# ============== Backend ==============
ASTRA_ENV=dev
ASTRA_DB_DIR=./data
ASTRA_JWT_SECRET=your-super-secret-jwt-key-change-in-production
ASTRA_JWT_ACCESS_MINUTES=30
ASTRA_JWT_REFRESH_DAYS=30
ASTRA_CORS_ORIGINS=http://localhost:3000,http://localhost:1420
ASTRA_AI_MODE=OFF
ASTRA_OFFLINE_MODE=false
ASTRA_DRIVE_ENABLED=false
ASTRA_GOOGLE_CLIENT_ID=
ASTRA_GOOGLE_CLIENT_SECRET=
ASTRA_GOOGLE_REDIRECT_URI=http://localhost:8000/sync/oauth/callback
ASTRA_BACKUP_PASSPHRASE_HINT=
ASTRA_ENCRYPTION_KDF=argon2id
ASTRA_ENCRYPTION_SALT=
ASTRA_SYNC_FOLDER_NAME=Pokimate_Backups

# ============== Web ==============
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_AI_MODE=OFF
NEXT_PUBLIC_OFFLINE_MODE=false

# ============== Mobile ==============
EXPO_PUBLIC_API_BASE=http://YOUR_LAN_IP:8000
EXPO_PUBLIC_AI_MODE=OFF
EXPO_PUBLIC_OFFLINE_MODE=false

# ============== Desktop ==============
# API base points to local backend (e.g. http://localhost:8000)
